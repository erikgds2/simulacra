# =============================================================
# Simulacra — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# =============================================================

# Obrigatório — obtenha em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-

# Opcional — Twitter/X API para coleta adicional de seeds
TWITTER_BEARER_TOKEN=

# Origens permitidas para CORS (separadas por vírgula)
# Em produção, substitua pelo domínio real do frontend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Ambiente: development ou production
ENVIRONMENT=development

# Banco de dados (SQLite por padrão — sem configuração necessária)
DATABASE_URL=sqlite:///./simulacra.db

# Diretório de dados persistentes (padrão: pasta local, produção: /data no Render)
DATA_DIR=
