# Simulacra — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# OBRIGATÓRIO — Chave da API Anthropic para geração de relatórios
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OPCIONAL — Configuração SMTP para alertas por e-mail
# Deixe em branco para desabilitar alertas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=seu@email.com

# OPCIONAL — Origens CORS permitidas (padrão: localhost dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# OPCIONAL — Diretório de dados persistentes (padrão: pasta do backend)
DATA_DIR=./data

# OPCIONAL — Ambiente (development | production | test)
ENVIRONMENT=development
